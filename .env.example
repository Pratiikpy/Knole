# Knole — environment template. Copy to .env and fill in. NEVER commit .env.
# Testnet only. Rotate everything before mainnet / real funds.

# ── Auth (Privy) ──────────────────────────────────────────
# VITE_-prefixed is exposed to the client; the secret is server-only.
VITE_PRIVY_APP_ID=
PRIVY_APP_SECRET=
VITE_APP_URL=http://localhost:3000

# ── 0G Galileo testnet ────────────────────────────────────
OG_NETWORK=testnet
OG_CHAIN_ID=16602
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_CHAIN_EXPLORER=https://chainscan-galileo.0g.ai

# Funded testnet wallet — pays storage + gas. Used to derive the per-user
# encryption key in dev. (Production: HKDF + KMS, not a raw key in .env.)
EVM_WALLET_ADDRESS=
EVM_PRIVATE_KEY=

# Encryption KDF master secret (HKDF) — derives per-user AES keys. Keep SEPARATE
# from the signing key above. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KNOLE_KDF_SECRET=
# Rotation: add KNOLE_KDF_SECRET_V2 (then _V3, …) to rotate. New entries encrypt under the highest
# version; older entries still decrypt under their original (the GCM auth tag picks the key). Never
# reuse or delete an old version while data encrypted under it still exists.
# KNOLE_KDF_SECRET_V2=
# Production custody: rather than a plaintext secret here, fetch it from a KMS/enclave at boot and
# call keyProvider.injectMasterSecret(version, secret) so the raw secret never sits in a file (SECURITY.md).

# ── 0G Sealed Inference (0G Private Compute / TEE) ────────
OG_COMPUTE_PROVIDER=
ZG_MODEL=qwen/qwen-2.5-7b-instruct
# "on" routes reflections through the TEE; needs a funded compute ledger.
OG_SEALED_INFERENCE=off
ZG_SERVICE_URL=
ZG_API_SECRET=

# ── LLM (NVIDIA NIM — dev primary + fallback) ─────────────
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=meta/llama-3.3-70b-instruct

# ── Database (Neon Postgres + pgvector) ───────────────────
DATABASE_URL=

# ── Billing (Stripe — optional; the upgrade flow stays honest + disabled when unset) ──
# Test mode first (sk_test_… / price_…). The webhook secret comes from the Stripe dashboard
# endpoint pointed at <your-origin>/stripe/webhook. Entitlement (users.plan) is flipped ONLY by
# verified webhooks — never by the client.
STRIPE_SECRET_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_WEBHOOK_SECRET=

# Optional: absolute base URL for social-share tags (og:image/og:url). Leave unset locally.
VITE_SITE_URL=

# ── Production / optional (sensible defaults — set only to override) ───────
# Public deploy: require a real session for writes, so anonymous visitors get the
# seeded demo read-only instead of being able to modify it.
KNOLE_REQUIRE_AUTH=off
# Vercel Cron auth — the Bearer token the scheduler sends to /api/cron/dream to run
# nightly Dreaming. Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=
# Separate seal for the session cookie; falls back to KNOLE_KDF_SECRET if unset.
SESSION_SECRET=
# Resilience tunables (ms / retry count) — uncomment to override the defaults.
# LLM_TIMEOUT_MS=
# LLM_MAX_RETRIES=
# OG_TIMEOUT_MS=
# OG_UPLOAD_TIMEOUT_MS=
# Dreaming worker — tick interval, and the per-tick time budget (keep < the serverless cap).
# WORKER_TICK_MS=
# WORKER_TICK_BUDGET_MS=
# Local testing only — point the demo/showcase user at a throwaway privy_id (default "demo")
# so exercising the write flow locally doesn't mutate the real demo.
# DEMO_PRIVY_ID=
