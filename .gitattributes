# Normalize line endings: LF in the repo and the working tree on every platform,
# so diffs stay clean and Windows checkouts don't rewrite every file to CRLF.
* text=auto eol=lf

# Binary assets — never apply line-ending conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
